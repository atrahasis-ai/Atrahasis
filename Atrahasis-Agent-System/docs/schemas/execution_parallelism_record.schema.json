{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "AAS5 Execution Parallelism Record",
  "type": "object",
  "required": [
    "type",
    "task_id",
    "workflow_id",
    "run_key",
    "generated_at",
    "updated_at",
    "simultaneous_target_agent_count",
    "execution_parallelism_mode",
    "total_agents_spawned",
    "total_children_spawned",
    "total_grandchildren_spawned",
    "max_live_concurrent_agents",
    "max_live_concurrent_children",
    "max_live_concurrent_grandchildren",
    "actual_parallel_agent_count",
    "batch_count",
    "batch_structure",
    "runtime_limit_evidence"
  ],
  "properties": {
    "type": {"const": "EXECUTION_PARALLELISM_RECORD"},
    "task_id": {"type": "string"},
    "workflow_id": {"type": "string"},
    "run_key": {"type": "string"},
    "generated_at": {"type": "string", "format": "date-time"},
    "updated_at": {"type": "string", "format": "date-time"},
    "simultaneous_target_agent_count": {"type": "integer", "minimum": 1},
    "execution_parallelism_mode": {"type": "string"},
    "total_agents_spawned": {"type": "integer", "minimum": 0},
    "total_children_spawned": {"type": "integer", "minimum": 0},
    "total_grandchildren_spawned": {"type": "integer", "minimum": 0},
    "max_live_concurrent_agents": {"type": "integer", "minimum": 0},
    "max_live_concurrent_children": {"type": "integer", "minimum": 0},
    "max_live_concurrent_grandchildren": {"type": "integer", "minimum": 0},
    "actual_parallel_agent_count": {"type": "integer", "minimum": 0},
    "batch_count": {"type": "integer", "minimum": 1},
    "batch_structure": {"type": "array", "items": {"type": "object"}},
    "runtime_limit_evidence": {"type": "array", "items": {"type": "object"}},
    "notes": {"type": "array", "items": {"type": "string"}}
  },
  "additionalProperties": true
}

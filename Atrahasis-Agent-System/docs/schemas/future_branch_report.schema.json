{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "AAS Future Branch Report",
  "type": "object",
  "required": [
    "type",
    "task_id",
    "workflow_id",
    "dispatch_id",
    "team_mode",
    "current_stage",
    "convergence_owner",
    "convergence_artifact",
    "recommendation_authorized",
    "blocking_gates",
    "branches",
    "created_at",
    "updated_at"
  ],
  "properties": {
    "type": {"const": "FUTURE_BRANCH_REPORT"},
    "doctrine_version": {"type": "string"},
    "topology_mode": {"type": "string"},
    "task_id": {"type": "string"},
    "workflow_id": {"type": "string"},
    "run_key": {"type": "string"},
    "dispatch_id": {"type": "string"},
    "team_mode": {"type": "string"},
    "current_stage": {"type": "string"},
    "convergence_owner": {"type": "string"},
    "convergence_artifact": {"type": "string"},
    "recommendation_authorized": {"type": "boolean"},
    "blocking_gates": {"type": "array", "items": {"type": "string"}},
    "improvement_trigger_policy": {"type": "object"},
    "radical_trigger_policy": {"type": "object"},
    "lane_report_refs": {"type": "object"},
    "audit_refs": {"type": "object"},
    "lane_summaries": {"type": "array", "items": {"type": "object"}},
    "branches": {"type": "array", "items": {"type": "object"}},
    "created_at": {"type": "string", "format": "date-time"},
    "updated_at": {"type": "string", "format": "date-time"}
  },
  "additionalProperties": true
}

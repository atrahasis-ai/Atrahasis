{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "required": [
    "type",
    "task_id",
    "task_title",
    "completed_on",
    "workflow_status",
    "changed_files",
    "changed_components"
  ],
  "properties": {
    "type": {"const": "SHARED_STATE_CLOSEOUT_RECORD"},
    "task_id": {"type": "string"},
    "task_title": {"type": "string"},
    "completed_on": {"type": "string"},
    "workflow_status": {"type": "string"},
    "operator_decision": {"type": ["string", "null"]},
    "invention_ids": {"type": "array", "items": {"type": "string"}},
    "notes": {"type": "array", "items": {"type": "string"}},
    "changed_files": {"type": "array", "items": {"type": "string"}},
    "changed_components": {"type": "object"}
  },
  "additionalProperties": true
}

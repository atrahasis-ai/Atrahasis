{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "AAS Swarm Execution Record",
  "type": "object",
  "required": [
    "type",
    "task_id",
    "stage",
    "generated_at",
    "swarm_requirement",
    "runtime_capabilities",
    "execution_mode",
    "parent_session",
    "required_child_roles",
    "spawned_children",
    "internal_viewpoint_roles",
    "merge_evidence",
    "recommendation_authorized",
    "satisfied"
  ],
  "properties": {
    "type": {"const": "SWARM_EXECUTION_RECORD"},
    "doctrine_version": {"type": "string"},
    "topology_mode": {"type": "string"},
    "task_id": {"type": "string"},
    "workflow_id": {"type": "string"},
    "run_key": {"type": "string"},
    "stage": {"type": "string"},
    "generated_at": {"type": "string", "format": "date-time"},
    "swarm_requirement": {"type": "object"},
    "runtime_capabilities": {"type": "object"},
    "execution_mode": {"type": "string"},
    "execution_parallelism_mode": {"type": "string"},
    "parent_session": {"type": "object"},
    "required_child_roles": {"type": "array", "items": {"type": "string"}},
    "required_child_ids": {"type": "array", "items": {"type": "string"}},
    "required_node_ids": {"type": "array", "items": {"type": "string"}},
    "required_manager_ids": {"type": "array", "items": {"type": "string"}},
    "required_reporter_ids": {"type": "array", "items": {"type": "string"}},
    "required_auditor_ids": {"type": "array", "items": {"type": "string"}},
    "required_worker_node_ids": {"type": "array", "items": {"type": "string"}},
    "spawned_children": {"type": "array", "items": {"type": "object"}},
    "internal_viewpoint_roles": {"type": "array", "items": {"type": "string"}},
    "merge_evidence": {"type": "object"},
    "blocking_reason": {"type": ["string", "null"]},
    "recommendation_authorized": {"type": "boolean"},
    "notes": {"type": "array", "items": {"type": "string"}},
    "satisfied": {"type": "boolean"}
  },
  "additionalProperties": true
}

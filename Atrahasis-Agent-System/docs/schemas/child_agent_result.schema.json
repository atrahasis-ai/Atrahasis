{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "AAS Child Agent Result",
  "type": "object",
  "required": [
    "type",
    "task_id",
    "role",
    "objective",
    "status",
    "session_identity",
    "model_audit",
    "artifact_provenance",
    "verdict",
    "evidence",
    "recommended_next_action"
  ],
  "properties": {
    "type": {"const": "CHILD_AGENT_RESULT"},
    "doctrine_version": {"type": "string"},
    "task_id": {"type": "string"},
    "workflow_id": {"type": "string"},
    "run_key": {"type": "string"},
    "node_id": {"type": "string"},
    "parent_node_id": {"type": ["string", "null"]},
    "role": {"type": "string"},
    "role_label": {"type": "string"},
    "objective": {"type": "string"},
    "status": {"type": "string"},
    "branch_id": {"type": ["string", "null"]},
    "branch_label": {"type": ["string", "null"]},
    "parent_role": {"type": ["string", "null"]},
    "branch_kind": {"type": ["string", "null"]},
    "lane_id": {"type": ["string", "null"]},
    "lane_label": {"type": ["string", "null"]},
    "lane_strategy": {"type": ["string", "null"]},
    "audit_domain": {"type": ["string", "null"]},
    "session_identity": {"type": "object"},
    "model_audit": {"type": "object"},
    "artifact_provenance": {"type": "object"},
    "verdict": {"type": "string"},
    "evidence": {"type": "array", "items": {"type": "object"}},
    "recommended_next_action": {"type": "string"}
  },
  "additionalProperties": true
}

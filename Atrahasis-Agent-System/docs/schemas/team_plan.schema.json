{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "AAS Team Plan",
  "type": "object",
  "required": [
    "version",
    "task_id",
    "workflow_id",
    "dispatch_id",
    "status",
    "created_at",
    "updated_at",
    "selection",
    "parent",
    "spawn_policy",
    "context_refs",
    "children",
    "notes"
  ],
  "properties": {
    "version": {"type": "string"},
    "doctrine_version": {"type": "string"},
    "topology_mode": {"type": "string"},
    "task_id": {"type": "string"},
    "workflow_id": {"type": "string"},
    "run_key": {"type": "string"},
    "dispatch_id": {"type": "string"},
    "status": {"type": "string"},
    "created_at": {"type": "string", "format": "date-time"},
    "updated_at": {"type": "string", "format": "date-time"},
    "selection": {"type": "object"},
    "parent": {"type": "object"},
    "spawn_policy": {"type": "object"},
    "manager_orchestrators": {"type": "array", "items": {"type": "object"}},
    "lane_convergence_reporters": {"type": "array", "items": {"type": "object"}},
    "audit_orchestrators": {"type": "array", "items": {"type": "object"}},
    "workers": {"type": "array", "items": {"type": "object"}},
    "context_refs": {"type": "array", "items": {"type": "string"}},
    "children": {"type": "array", "items": {"type": "object"}},
    "future_exploration": {"type": "object"},
    "notes": {"type": "array", "items": {"type": "string"}}
  },
  "additionalProperties": true
}

{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "AAS5 Audit Record",
  "type": "object",
  "required": [
    "type",
    "task_id",
    "workflow_id",
    "run_key",
    "owner_node_id",
    "generated_at",
    "updated_at",
    "status",
    "recommendation_authorized",
    "blocking_gates",
    "summary"
  ],
  "properties": {
    "type": {"type": "string"},
    "task_id": {"type": "string"},
    "workflow_id": {"type": "string"},
    "run_key": {"type": "string"},
    "owner_node_id": {"type": "string"},
    "generated_at": {"type": "string", "format": "date-time"},
    "updated_at": {"type": "string", "format": "date-time"},
    "status": {"type": "string"},
    "recommendation_authorized": {"type": "boolean"},
    "blocking_gates": {"type": "array", "items": {"type": "string"}},
    "summary": {"type": "string"},
    "notes": {"type": "array", "items": {"type": "string"}}
  },
  "additionalProperties": true
}

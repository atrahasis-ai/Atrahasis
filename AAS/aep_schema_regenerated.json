{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Architecture Evolution Proposal",
  "type": "object",
  "required": [
    "aep_id",
    "title",
    "authoring_agent",
    "date",
    "problem_statement",
    "invention_concept",
    "architecture_gap",
    "proposed_architecture_change",
    "affected_layers",
    "cssm_version"
  ],
  "properties": {
    "aep_id": {
      "type": "string"
    },
    "title": {
      "type": "string"
    },
    "authoring_agent": {
      "type": "string"
    },
    "date": {
      "type": "string"
    },
    "status": {
      "type": "string",
      "enum": [
        "draft",
        "submitted",
        "approved",
        "approved_with_modifications",
        "rejected",
        "deferred"
      ]
    },
    "cssm_version": {
      "type": "string"
    },
    "problem_statement": {
      "type": "string"
    },
    "invention_concept": {
      "type": "string"
    },
    "architecture_gap": {
      "type": "string"
    },
    "proposed_architecture_change": {
      "type": "string"
    },
    "affected_layers": {
      "type": "array",
      "items": {
        "type": "string",
        "enum": [
          "Infrastructure",
          "Runtime",
          "Registry",
          "Identity",
          "Protocol",
          "Agent",
          "Governance",
          "Bridge"
        ]
      }
    },
    "data_model_changes": {
      "type": "string"
    },
    "protocol_implications": {
      "type": "string"
    },
    "security_implications": {
      "type": "string"
    },
    "governance_implications": {
      "type": "string"
    },
    "migration_strategy": {
      "type": "string"
    },
    "implementation_tasks": {
      "type": "array",
      "items": {
        "type": "string"
      }
    }
  }
}
      ],
      "decision_id": "CDR-003",
      "decision_outcome": "approved_with_modifications",
      "proposal_id": "AEP-GAMMA-001",
      "reasoning": "The event-sourced control plane materially increases recursive evolution power, but it must not replace human override or the existing shared-state authority boundary.",
      "requested_modifications": [
        "Keep the control plane file-backed and local during bootstrap.",
        "Preserve explicit human override and council arbitration as first-class invariants."
      ]
    },

        "Runtime Council",
        "Registry Council"
      ],
      "decision_id": "CDR-002",
      "decision_outcome": "approved",
      "proposal_id": "AEP-BETA-001",
      "reasoning": "A machine-readable ACR, proposal registry, and task graph are required for capability-driven execution and are compatible with the current operating model.",
      "requested_modifications": []
    },
    {
